# ============================================================
# MiSi Screener - Environment Variables Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit your .env file to version control.
# ============================================================

# --- Data Sources ---
# Alpha Vantage (for fundamental data: income statements, company overview)
# Get a free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# NewsAPI (for news headlines and sentiment analysis)
# Get a free key at: https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here

# --- Broker Integration ---
# Alpaca (for paper/live trading and market data)
# Get keys at: https://app.alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
# Use paper trading URL for testing, or live URL for real trading
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Database ---
# SQLite database path (default: misi_hedge_fund.db in project root)
# DB_PATH=misi_hedge_fund.db

# --- Logging ---
# Log file path (default: misi_screener.log in project root)
# LOG_FILE=misi_screener.log
